@EnableBatchProcessing
@SpringBootApplication
public class FileCopy2Application {

	private final Constants constants;

	@Autowired
	private JobBuilderFactory jobBuilderFactory;

	@Autowired
	private StepBuilderFactory stepBuilderFactory;

	FileCopy2Application(Constants constants) {
		this.constants = constants;
	}
	
	private void insertionSort(List arr) {

		for(int i = 1; i < arr.size; i++) {
			int key = arr.get(i);
			int j = i - 1;
			
			// 이전의 원소가 더크다면 데이터는 하나씩 밀려난다.
			while(j >= 0 && arr.get(j) > key){
			arr.set(j+1,arr.get(j));
			j--;
		}
		arr.set(j+1, key);
		
		System.out.println(" arr :: "+arr.toString());
	}
	
    @Bean
    public Step step() {        
		return this.stepBuilderFactory.get("step1")
				.tasklet(new Tasklet() {
					@Override
					public RepeatStatus execute(StepContribution contribution,
							ChunkContext chunkContext) throws Exception {

						System.out.println(" step start ");
				
						List<Integer> arr = Arrays.asList(5, 3, 1, 4, 2);
						insertionSort(arr);
						
						System.out.println(" step end !");
						return RepeatStatus.FINISHED;
					}

				}).build();
    }
    
    @Bean
    public Job job() {
		return this.jobBuilderFactory.get("job")
				.start(step())
				.build();
    }
	
	public static void main(String[] args) {
		SpringApplication.run(FileCopy2Application.class, args);
	}

}
