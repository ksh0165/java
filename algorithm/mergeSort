@EnableBatchProcessing
@SpringBootApplication
public class FileCopy2Application {

	private final Constants constants;

	@Autowired
	private JobBuilderFactory jobBuilderFactory;

	@Autowired
	private StepBuilderFactory stepBuilderFactory;

	FileCopy2Application(Constants constants) {
		this.constants = constants;
	}
	
	/*
	 * 부분 리스트는 arr 배열의 left ~ right 까지이다.
	 * 
	 * arr 정렬할 배열
	 * left 배열의 시작점
	 * mid 배열의 중간점
	 * right 배열의 끝 점
	 */
	static void print(int arr[], int left, int right) {
		for(int i = 0; i < arr.length; i++) {
			if(i == left) {
				System.out.print("[");
			}
			System.out.print(arr[i]);
			if(i == right) {
				System.out.print("] ");
			}else {
				System.out.print(" ");
			}
		}
		System.out.println();
	}
	
	static void merge(int arr[], int left, int mid, int right) {
		int[] left_arr = Arrays.copyOfRange(arr, left, mid + 1);
		int[] right_arr = Arrays.copyOfRange(arr,  mid + 1, right + 1);
		
		int leftIdx = left; //왼쪽 배열 검사 인덱스
		int rightIdx = mid+1; //오른쪽 배열 검사 인덱스
		int mIdx = left; // 합변중인 배열의 현재 인덱스
		
		int[] sorted = new int[arr.length]; // 정렬된 수를 넣어줄 배열
		
		while(leftIdx <= mid && rightIdx <= right) {
			if(arr[leftIdx]<arr[rightIdx]) sorted[mIdx++] = arr[leftIdx++];
			else sorted[mIdx++] = arr[rightIdx++];
		}
		
		// 남은거 처리
		while(leftIdx <= mid) sorted[mIdx++] = arr[leftIdx++];
		while(rightIdx <= right) sorted[mIdx] = arr[rightIdx++];
		
		// 원래 배열에 정렬된 배열 넣어줌
		while(--mIdx>=left) {
			arr[mIdx] = sorted[mIdx];
		}
		
		print(arr, left, right);
	}
	
	static void mergeSort(int[] arr, int left, int right) {
		if(left < right) {
			int mid = (right + left) / 2;
			mergeSort(arr, left, mid);
			mergeSort(arr, mid + 1, right);
			merge(arr, left, mid, right);
		}
	}
	
	static void sort(int arr[]) {
		mergeSort(arr, 0, arr.length -1);
	}
	
    @Bean
    public Step step() {        
		return this.stepBuilderFactory.get("step1")
				.tasklet(new Tasklet() {
					@Override
					public RepeatStatus execute(StepContribution contribution,
							ChunkContext chunkContext) throws Exception {

						System.out.println(" step start ");
				
						int[] arr = new int[] {6, 5, 3, 1, 8, 7, 2, 4};
						
						if(arr.length > 2) {							
							print(arr, -1,-1);
							sort(arr);
						}	
						
						System.out.println(" step end !");
						return RepeatStatus.FINISHED;
					}

				}).build();
    }
    
    @Bean
    public Job job() {
		return this.jobBuilderFactory.get("job")
				.start(step())
				.build();
    }
	
	public static void main(String[] args) {
		SpringApplication.run(FileCopy2Application.class, args);
	}

}
